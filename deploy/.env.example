# ── Aurora deploy config ────────────────────────────────────────────────
# Copy to .env and fill in. One root domain; the apps live on subdomains:
#   https://${DOMAIN}          player
#   https://admin.${DOMAIN}    admin / back-office
#   https://games.${DOMAIN}    game cabinet
#   https://api.${DOMAIN}      backend API
# Point all four A/AAAA records at this server's IP before deploying.

DOMAIN=aurora.example.com
ACME_EMAIL=you@example.com        # for Let's Encrypt (Caddy auto-HTTPS)

# Postgres
DB_USER=aurora
DB_PASSWORD=change_me_strong
DB_NAME=aurora

# JWT secrets — generate: openssl rand -hex 48
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh

# starting balance credited on register (0 = none)
SIGNUP_BONUS=0

# Game cabinet location. Defaults to a sibling folder of this repo.
# On a fresh server, set GAME_REPO to its git URL and deploy.sh will clone it.
# GAME_DIR=../../SlotGames/wrath-of-olympus
# GAME_REPO=https://github.com/you/wrath-of-olympus.git
