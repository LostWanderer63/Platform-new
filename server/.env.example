# --- Database ---
DATABASE_URL="postgresql://aurora:aurora@localhost:5432/aurora?schema=public"

# --- Server ---
PORT=4000
NODE_ENV=development
# comma-separated allowed origins for CORS (the Vite app)
CORS_ORIGINS="http://localhost:5173,http://localhost:5174"

# --- Auth (JWT) ---
# generate strong secrets in prod: openssl rand -hex 48
JWT_ACCESS_SECRET="dev_access_secret_change_me"
JWT_REFRESH_SECRET="dev_refresh_secret_change_me"
JWT_ACCESS_TTL="900"        # seconds (15m)
JWT_REFRESH_TTL="2592000"   # seconds (30d)
COOKIE_DOMAIN="localhost"
COOKIE_SECURE="false"       # true behind HTTPS in prod
# lax = same-site (one root domain). none = cross-site (apps on different
# domains, e.g. free hosts *.pages.dev + *.onrender.com); none forces Secure.
COOKIE_SAMESITE="lax"

# --- Gameplay ---
SIGNUP_BONUS="0"            # starting balance credited on register
